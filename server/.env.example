# Copy to server/.env and fill in.
# Postgres connection string. Use Neon's POOLED connection string for serverless/Vercel.
# Example (Neon): postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Secret used to sign JWT session tokens. Use a long random string in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Port for the local API server (Vite proxies /api here).
PORT=3001

# Optional. Comma-separated origin allowlist for CORS. Leave unset to allow all origins
# (fine on Vercel, where the frontend and /api are same-origin). Example:
# CORS_ORIGIN="https://your-app.vercel.app"
